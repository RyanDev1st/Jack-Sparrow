rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Hunters are now server-managed via App Router API routes only.
    match /hunters/{mantraId} {
      allow read, write: if true;
    }

    // Map authoring is still client-driven in the current architecture.
    match /map_sets/{mapSetId} {
      allow read, write: if true;
    }

    match /map_code_pools/{poolId} {
      allow read, write: if true;
    }

    // Active list and claim transitions are also server-managed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
